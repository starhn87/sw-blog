{
  "name": "sw-blog",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "browserslist": [
    "chrome >= 105",
    "edge >= 105",
    "firefox >= 104",
    "safari >= 16"
  ],
  "scripts": {
    "dev": "next dev --turbopack",
    "predev": "pnpm build:indexes",
    "build:indexes": "tsx scripts/build-search-index.ts && tsx scripts/build-rag-chunks.ts && tsx scripts/build-codebase-summary.ts",
    "prebuild": "tsx scripts/check-mdx-alt.ts && pnpm build:indexes",
    "build": "next build",
    "analyze": "ANALYZE=true next build",
    "pages:build": "pnpm prebuild && npx @cloudflare/next-on-pages",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && tsx scripts/check-mdx-alt.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@cloudflare/next-on-pages": "^1.13.16",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tailwindcss/typography": "^0.5.20",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.40.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.21.0",
    "next": "15.5.15",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^9.1.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-pretty-code": "^0.14.3",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.2.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260623.1",
    "@next/bundle-analyzer": "^16.2.9",
    "@next/eslint-plugin-next": "^15.5.19",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^25.9.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.5.0",
    "eslint-plugin-react": "^7.37.5",
    "postcss": "^8.5.15",
    "schema-dts": "^2.0.0",
    "sharp": "^0.35.2",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9",
    "wrangler": "^4.103.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}
